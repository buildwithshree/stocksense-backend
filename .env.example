# Neon PostgreSQL
DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=your_minimum_32_character_secret_here

# Python ML service URL (local or Render deployed)
ML_SERVICE_URL=http://localhost:8000

# Set by Render automatically — leave blank locally
PORT=8080
